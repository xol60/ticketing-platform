# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  TICKETING PLATFORM — Environment template                                  ║
# ║  Copy to .env and fill in real values. Never commit .env to version control.║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32+ characters). Use a random generator:
#   openssl rand -base64 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_32

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USER=ticketing
DB_PASSWORD=CHANGE_ME_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092
